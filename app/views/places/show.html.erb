<h1 class="mt-4"><%= @place["name"] %></h1>
<h2 class="mb-4">My Entries</h2>
<div class="row">
  <% for entry in @entries %>
    <div class="col-md-4 mb-3">
      <div class="card">
        <% if entry.uploaded_image.attached? %>
          <img src="<%= url_for(entry.uploaded_image) %>" class="card-img-top">
        <% end %>
        <div class="card-body">
          <h3 class="card-title"><%= entry["title"] %></h3>
          <h4 class="card-subtitle text-muted"><%= entry["occurred_on"] %></h4>
          <p class="card-text"><%= entry["description"] %></p>
        </div>
      </div>
    </div>
  <% end %>
</div>
<% if @current_user %>
  <p class="mt-3">
    <a class="btn btn-primary" href="/entries/new?place_id=<%= @place["id"] %>">New Entry</a>
  </p>
<% end %>
<p class="mb-4">
  <a href="/places">Back to All Places</a>
</p>
